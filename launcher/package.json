{
  "name": "ispoofermotion-launcher",
  "version": "1.0.0",
  "description": "External launcher/updater for ISpooferMotion official releases.",
  "main": "launcher.js",
  "license": "GPL-3.0-or-later",
  "bin": "launcher.js",
  "scripts": {
    "start": "node launcher.js",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
